<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EJS Tags</title>
</head>

<body>
  <h1>
    EJS Tags
  </h1>
  <p>Current second:
    <%= seconds %>
  </p>
  <% if (seconds % 2 === 0) { %>
    <ul>
      <li>apple</li>
      <li>banana</li>
      <li>cherry</li>
  </ul>
  <% } else { %>
    <p>No items to display</p>
  <% } %>
  <p>
    <em>This is some em text.</em>
  </p>

  <!-- Footer goes here -->
  <%- include("footer") %>
</body>

</html>