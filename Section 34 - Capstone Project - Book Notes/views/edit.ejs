<%- include('partials/header.ejs'); -%>

<h1>Burns Book Blog</h1>

<div>
  <a href="/">
    <button type="submit">Back</button>
  </a>

  <a href="/delete" method="post">
    <button type="submit">Delete Book</button>
  </a>
</div>


<form action="/edit?id=<%= book.id %>" method="post">
  <div>
    <label for="title">Title: </label>
  <input type="text" id="title" name="title" value="<%= book.title %>">
  </div>
  
  <div>
    <label for="author">Author: </label>
  <input type="text" id="author" name="author" value="<%= book.author %>">
  </div>
  
  <div>
    <label for="yr_pub">Year Published: </label>
    <input type="text" id="yr_pub" name="yr_pub" value="<%= book.yr_pub %>">
  </div>
  
  <div>
    <label for="yr_read">Year Read: </label>
    <input type="text" id="yr_read" name="yr_read" value="<%= book.yr_read %>">
  </div>
  
  <div>
    <label for="rating">Rating: </label>
    <select name="rating" id="rating">
        <option value="1">⭐</option>
        <option value="2">⭐⭐</option>
        <option value="3">⭐⭐⭐</option>
        <option value="4">⭐⭐⭐⭐</option>
        <option value="5">⭐⭐⭐⭐⭐</option>
      </select>
    </div>
    
    <div>
      <label for="cover_url">Cover Image URL: </label>
      <input type="text" id="cover_url" name="cover_url" value="<%= book.cover_url %>">
    </div>

    <div>
      <label for="summary">Summary: </label>
      <textarea name="summary" id="summary"></textarea>
    </div>
    <button type="submit">Submit</button>
</form>


<h2><%= book.title %></h2>
<h3><%= book.author %></h3>
<h4><%= book.yr_pub %></h4>
<h4><%= book.yr_read %></h4>
<h4><%= "⭐".repeat(book.rating) %></h4>
<p><%= book.summary %></p>
<img src="<%= book.cover_url %>" alt="Book cover">

<%- include('partials/footer.ejs'); -%>